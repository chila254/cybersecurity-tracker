# Database
DATABASE_URL=postgresql://user:password@localhost:5432/incident_tracker

# JWT & Security
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# Email Notifications (Gmail, SendGrid, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@cybersecurity-tracker.com

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "https://cybersecurity-tracker.vercel.app"]

# Environment
ENVIRONMENT=production
PORT=8000
